# Stage AI Labs Owner Console - local runtime
# Copy this file to .env.local and fill the private values on your PC.

# Required for local server actions that update owner-console Supabase tables.
STAGE_SUPABASE_SERVICE_ROLE_KEY=

# Required for Bot Builder "Save to GitHub".
STAGE_GITHUB_TOKEN=
STAGE_BOT_TEMPLATE_REPO=YovngScott/Stage-Bot-Template
STAGE_BOT_TEMPLATE_BRANCH=main

# Required to link a bot so Client Manager can turn it on/off.
STAGE_PLATFORM_ADMIN_SECRET=

# Required for "Create dashboard user" in a client's Access tab.
STAGE_MESSAGING_SUPABASE_URL=https://vulyyztktylldfnuvzbn.supabase.co
STAGE_MESSAGING_SUPABASE_SERVICE_ROLE_KEY=

# Local client-dashboard preview URL.
STAGE_LOCAL_CLIENT_DASHBOARD_URL=http://127.0.0.1:5174/
